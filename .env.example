# ═══════════════════════════════════════════════
# BIZNES MIYASI BOT — Konfiguratsiya
# Bu faylni .env ga nusxalang va to'ldiring
# ═══════════════════════════════════════════════

# 🤖 Telegram Bot Token (@BotFather dan oling)
BOT_TOKEN=your_bot_token_here

# 🌐 Mini App URL (GitHub Pages yoki Vercel)
WEBAPP_URL=https://your-username.github.io/biznes-miyasi-miniapp/

# 🧠 AI API Keys (kamida bittasi kerak)
# Google Gemini (BEPUL! — https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI GPT-4o (ixtiyoriy, faqat murakkab so'rovlar uchun)
OPENAI_API_KEY=your_openai_api_key

# 💾 Database
DATABASE_PATH=biznes_miyasi.db
